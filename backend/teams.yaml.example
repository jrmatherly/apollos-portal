# Entra ID Security Group -> LiteLLM Team Mapping
# Each entry maps an Entra group to a LiteLLM team with its configuration.
# Users in multiple groups are provisioned into multiple teams (one key per team).

teams:
  - entra_group_id: "REPLACE-WITH-ENTRA-GROUP-OBJECT-ID"
    team_alias: "Engineering AI Team"
    models:
      - "gpt-5.2"
      - "gpt-5.1-codex"
      - "gpt-5"
      - "gpt-5-mini"
      - "gpt-5-nano"
      - "text-embedding-3-large"
      - "text-embedding-3-small"
    max_budget: 500
    budget_duration: "30d"
    team_member_budget: 25
    litellm_role: "user"

  # Default/fallback team — suppressed when the user qualifies for a non-default team.
  # Only used when a user has no other team membership.
  # - entra_group_id: "REPLACE-WITH-FALLBACK-GROUP-OBJECT-ID"
  #   team_alias: "All Users"
  #   models: ["gpt-5-mini"]
  #   max_budget: 50
  #   budget_duration: "30d"
  #   is_default: true

# Gate: user must be in at least one of these groups to access the portal.
# If omitted, membership in any team group above qualifies.
required_groups: []
  # - "REPLACE-WITH-GATE-GROUP-OBJECT-ID"
