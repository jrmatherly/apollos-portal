# --- Entra ID ---
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=http://localhost:3000/auth/callback

# --- LiteLLM ---
LITELLM_BASE_URL=http://litellm:4000
LITELLM_MASTER_KEY=sk-change-me

# --- Database ---
DATABASE_URL=postgresql+asyncpg://portal:portal@localhost:5432/apollos_portal

# --- Email (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# --- Portal ---
PORTAL_BASE_URL=http://localhost:3000
DEFAULT_KEY_DURATION_DAYS=90
PORTAL_ADMIN_ROLE=portal_admin

# --- Cron Schedules ---
NOTIFICATION_CRON_SCHEDULE=0 9 * * *
ROTATION_CRON_SCHEDULE=0 */6 * * *
DEPROVISIONING_CRON_SCHEDULE=0 */6 * * *
RECONCILIATION_CRON_SCHEDULE=0 2 * * *

# --- Teams Config ---
TEAMS_CONFIG_PATH=teams.yaml
