{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Apollos AI",
  "colors": {
    "primary": "#6366F1",
    "light": "#818CF8",
    "dark": "#4F46E5"
  },
  "favicon": "/images/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": ["index", "quickstart", "development"]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/authentication",
              "concepts/teams",
              "concepts/api-keys",
              "concepts/usage"
            ]
          },
          {
            "group": "CLI",
            "pages": ["cli/overview"]
          },
          {
            "group": "Administration",
            "pages": ["administration/entra-id-setup"]
          }
        ]
      },
      {
        "tab": "API reference",
        "openapi": "api-reference/openapi.json",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api-reference/introduction"]
          },
          {
            "group": "User endpoints",
            "pages": [
              "GET /api/v1/me",
              "GET /api/v1/status",
              "POST /api/v1/provision",
              "GET /api/v1/keys",
              "POST /api/v1/keys/new",
              "POST /api/v1/keys/{key_id}/rotate",
              "POST /api/v1/keys/{key_id}/revoke",
              "GET /api/v1/teams",
              "GET /api/v1/usage",
              "GET /api/v1/models",
              "GET /api/v1/settings",
              "PATCH /api/v1/settings"
            ]
          },
          {
            "group": "Admin endpoints",
            "pages": [
              "GET /api/v1/admin/users",
              "GET /api/v1/admin/users/{user_id}",
              "POST /api/v1/admin/users/{user_id}/deprovision",
              "POST /api/v1/admin/users/{user_id}/reprovision",
              "GET /api/v1/admin/keys",
              "POST /api/v1/admin/keys/{key_id}/revoke",
              "GET /api/v1/admin/audit",
              "GET /api/v1/admin/audit/export",
              "GET /api/v1/admin/health"
            ]
          },
          {
            "group": "Health checks",
            "pages": [
              "GET /health",
              "GET /ready"
            ]
          }
        ]
      },
      {
        "tab": "Contributing",
        "groups": [
          {
            "group": "Contributing",
            "pages": ["contributing/overview", "contributing/development"]
          },
          {
            "group": "AI tools",
            "pages": [
              "ai-tools/claude-code",
              "ai-tools/cursor",
              "ai-tools/windsurf"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/jrmatherly/apollos-portal",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/images/apollos_new_circle_no_bg_sm.png",
    "dark": "/images/apollos_new_circle_no_bg_sm.png"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/jrmatherly/apollos-portal"
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/jrmatherly/apollos-portal"
    }
  }
}
